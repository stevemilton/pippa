# ── IBKR Connection ──────────────────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=1

# Docker IB Gateway credentials
IBKR_USERNAME=your_ibkr_username
IBKR_PASSWORD=your_ibkr_password
IBKR_TRADING_MODE=paper

# VNC password for IB Gateway (for initial setup)
VNC_PASSWORD=quantagent

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Scanner Config ───────────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=5
MISPRICING_THRESHOLD=0.03
MAX_INSTRUMENTS_PER_CLUSTER=6
PAPER_TRADING=true

# ── Database ─────────────────────────────────────────────────────────────────
DB_PATH=/opt/quantagent/quantagent.db

# ── Copula ───────────────────────────────────────────────────────────────────
COPULA_LOOKBACK_DAYS=60
COPULA_MIN_OBSERVATIONS=100
